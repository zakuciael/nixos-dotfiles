+// Resolves each path component of relPath against basePath case-insensitively.
+// On case-sensitive Linux filesystems (ext4, btrfs), requiredFiles declared by a game
+// extension may have different casing from what is on disk under Wine/Proton.
+// Upstream issue: https://github.com/Nexus-Mods/Vortex/issues/20439
+async function statCaseInsensitive(basePath: string, relPath: string): Promise<void> {
+  const components = relPath.split(/[/\\]/);
+  let current = basePath;
+  for (const component of components) {
+    if (!component) continue;
+    const entries = await fsExtra.readdir(current);
+    const match = entries.find(e => e.toLowerCase() === component.toLowerCase());
+    if (match === undefined) {
+      const err: NodeJS.ErrnoException = new Error(
+        `ENOENT: no such file or directory, stat '${path.join(current, component)}'`,
+      );
+      err.code = 'ENOENT';
+      throw err;
+    }
+    current = path.join(current, match);
+  }
+  await fsExtra.stat(current);
+}
